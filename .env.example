# Proxy configuration
PROXY_HOST=la.residential.rayobyte.com
PROXY_PORT=8000
PROXY_USERNAME=
PROXY_PASSWORD=
PROXY_COUNTRY=US

# TempMail API (optional, if using tempmail provider)
TEMPMAIL_API_KEY=

# Outlook pool file (optional, if using outlook provider)
# OUTLOOK_POOL_FILE=outlook_pool.txt

# Registration mode
# PUTER_LIVE_REGISTRATION=0

# Proxy for Ollama registration (optional, non-sticky/backward compatible)
# REGISTER_PROXY=http://user:pass@host:port
# PLAYWRIGHT_PROXY_SERVER=http://user:pass@host:port

# Sticky proxy for Ollama registration (optional)
# When enabled, one generated session id is reused by browser and HTTP helper traffic.
# OLLAMA_STICKY_PROXY=1
# PROXY_PROVIDER=rayobyte
# PROXY_SCHEME=http
# PROXY_HOST=la.residential.rayobyte.com
# PROXY_PORT=8000
# PROXY_USERNAME=
# PROXY_PASSWORD=
# PROXY_COUNTRY=US
# PROXY_SESSION_TEMPLATE={username}-session-{session}
# PROXY_URL_TEMPLATE={scheme}://{username}-session-{session}:{password}@{host}:{port}
# PROXY_IP_CHECK_URL=https://api.ipify.org?format=json

# Sticky proxy via extraction API (for providers such as B2Proxy dynamic residential)
# OLLAMA_STICKY_PROXY=1
# PROXY_PROVIDER=b2proxy
# PROXY_SCHEME=http
# PROXY_API_URL=http://global.rrp.bestgo.work:8089/gen?zone=custom&ptype=1&count=1&proto=http&stype=txt&sessType=sticky&split=%5Cr%5Cn&sessTime=20&sessAuto=1
# Keep browser/proxy drift checks sticky while helper APIs use direct connections if a provider resets them.
# PROXY_HELPERS_DIRECT=1

# Ollama browser fingerprint configuration
# OLLAMA_PROFILE_ROOT=ollama_profiles
# OLLAMA_FINGERPRINT_REGISTRY=ollama_fingerprints.json
# OLLAMA_FINGERPRINT_COUNTRY=US

# Artifacts directory (leave empty to disable)
# ARTIFACTS_DIR=artifacts

# Curl impersonate version
# CURL_IMPERSONATE=chrome136
# Optional new-api integration (not required for registration)
# NEWAPI_URL=http://127.0.0.1:3000
# NEWAPI_SESSION={"cookie":"session=...","user_id":"1"}
# NEWAPI_USERNAME=root
# NEWAPI_PASSWORD=
# GATEWAY_URL=http://127.0.0.1:8002
# MASTER_KEY=
